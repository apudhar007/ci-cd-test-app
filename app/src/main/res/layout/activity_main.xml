<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="#EEEEEE"
        android:gravity="end"
        android:padding="16dp"
        android:text="0"
        android:textSize="32sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <!-- Row 1 -->
        <Button android:id="@+id/btn7" android:text="7" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btn8" android:text="8" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btn9" android:text="9" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btnDiv" android:text="/" style="@style/Widget.MaterialComponents.Button.Colored"/>

        <!-- Row 2 -->
        <Button android:id="@+id/btn4" android:text="4" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btn5" android:text="5" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btn6" android:text="6" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btnMul" android:text="*" style="@style/Widget.MaterialComponents.Button.Colored"/>

        <!-- Row 3 -->
        <Button android:id="@+id/btn1" android:text="1" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btn2" android:text="2" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btn3" android:text="3" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btnSub" android:text="-" style="@style/Widget.MaterialComponents.Button.Colored"/>

        <!-- Row 4 -->
        <Button android:id="@+id/btnC" android:text="C" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn0" android:text="0" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        <Button android:id="@+id/btnEq" android:text="=" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btnAdd" android:text="+" style="@style/Widget.MaterialComponents.Button.Colored"/>

    </GridLayout>

</LinearLayout>